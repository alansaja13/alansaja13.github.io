<script>
  function initInteractive() {
    const cv = document.getElementById('bg-canvas') as HTMLCanvasElement;
    if (!cv) return;
    const ctx = cv.getContext('2d')!;

    function resize() {
      cv.width = window.innerWidth;
      cv.height = window.innerHeight;
    }
    resize();
    window.addEventListener('resize', resize);

    const mouse = { x: window.innerWidth / 2, y: window.innerHeight / 2 };
    const target = { x: mouse.x, y: mouse.y };

    window.addEventListener('mousemove', (e) => {
      target.x = e.clientX;
      target.y = e.clientY;
    });

    const pts = Array.from({ length: 80 }, () => ({
      x: Math.random() * window.innerWidth,
      y: Math.random() * window.innerHeight,
      vx: (Math.random() - 0.5) * 0.2,
      vy: (Math.random() - 0.5) * 0.2,
      r: Math.random() * 1.5 + 0.5,
      op: Math.random() * 0.2 + 0.05,
    }));

    const waves: { x: number; y: number; r: number; op: number }[] = [];

    document.addEventListener('click', (e) => {
      const t = e.target as HTMLElement;
      if (t.closest('.obj')) return;
      waves.push({ x: e.clientX, y: e.clientY, r: 0, op: 0.4 });
    });

    function drawWaves() {
      for (let i = waves.length - 1; i >= 0; i--) {
        const w = waves[i];
        w.r += 4;
        w.op *= 0.94;
        for (const p of pts) {
          const dx = p.x - w.x;
          const dy = p.y - w.y;
          const d = Math.hypot(dx, dy);
          const diff = Math.abs(d - w.r);
          if (diff < 30 && d > 0) {
            const f = ((30 - diff) / 30) * 1.2;
            p.vx += (dx / d) * f;
            p.vy += (dy / d) * f;
          }
        }
        if (w.op < 0.01) {
          waves.splice(i, 1);
          continue;
        }
        ctx.beginPath();
        ctx.arc(w.x, w.y, w.r, 0, Math.PI * 2);
        ctx.strokeStyle = `rgba(193, 39, 45, ${w.op * 0.2})`;
        ctx.lineWidth = 1;
        ctx.stroke();
      }
    }

    function frame() {
      mouse.x += (target.x - mouse.x) * 0.05;
      mouse.y += (target.y - mouse.y) * 0.05;
      ctx.clearRect(0, 0, cv.width, cv.height);

      for (const p of pts) {
        const dx = p.x - mouse.x;
        const dy = p.y - mouse.y;
        const d = Math.sqrt(dx * dx + dy * dy);
        if (d < 160 && d > 0) {
          const f = ((160 - d) / 160) * 0.4;
          p.vx += (dx / d) * f;
          p.vy += (dy / d) * f;
        }
        p.vx *= 0.95;
        p.vy *= 0.95;
        p.x += p.vx;
        p.y += p.vy;
        if (p.x < 0) p.x = cv.width;
        if (p.x > cv.width) p.x = 0;
        if (p.y < 0) p.y = cv.height;
        if (p.y > cv.height) p.y = 0;

        const blend = Math.max(0, 1 - d / 180);
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
      // Usando paleta Koban (#D4AF37) para dark y Crimson (#C1272D) para light
        const color = document.documentElement.classList.contains('dark') ? '212, 175, 55' : '193, 39, 45';
        ctx.fillStyle = `rgba(${color}, ${p.op + blend * 0.2})`;
        ctx.fill();
      }

      for (let i = 0; i < pts.length - 1; i++) {
        for (let j = i + 1; j < pts.length; j++) {
          const dx = pts[i].x - pts[j].x;
          const dy = pts[i].y - pts[j].y;
          const d = Math.sqrt(dx * dx + dy * dy);
          if (d < 100) {
            ctx.beginPath();
            ctx.moveTo(pts[i].x, pts[i].y);
            ctx.lineTo(pts[j].x, pts[j].y);
            const color = document.documentElement.classList.contains('dark') ? '212, 175, 55' : '193, 39, 45';
            ctx.strokeStyle = `rgba(${color}, ${0.05 * (1 - d / 100)})`;
            ctx.lineWidth = 0.5;
            ctx.stroke();
          }
        }
      }

      drawWaves();
      requestAnimationFrame(frame);
    }

    frame();

    // Parallax
    const objEls = document.querySelectorAll<HTMLElement>('.obj');
    window.addEventListener('mousemove', (e) => {
      const ox = (e.clientX - window.innerWidth / 2) / (window.innerWidth / 2);
      const oy = (e.clientY - window.innerHeight / 2) / (window.innerHeight / 2);
      objEls.forEach((el) => {
        const f = parseFloat(el.dataset.p ?? '0.3');
        const tx = ox * f * 30;
        const ty = oy * f * 30;
        el.style.transform = `translate(${tx}px, ${ty}px)`;
      });
    });

    // Eco flotante
    const ecoEl = document.getElementById('eco')!;
    let ecoTimer: ReturnType<typeof setTimeout>;

    objEls.forEach((el) => {
      el.addEventListener('click', (e) => {
        const msg = el.dataset.eco;
        if (!msg) return;

        clearTimeout(ecoTimer);
        ecoEl.style.transition = 'none';
        ecoEl.style.opacity = '0';
        ecoEl.style.transform = 'translateY(0px)';
        ecoEl.style.left = e.clientX + 'px';
        ecoEl.style.top = e.clientY + 'px';
        ecoEl.textContent = msg;

        ecoEl.getBoundingClientRect();
        ecoEl.style.transition = 'opacity 0.35s ease, transform 1.4s ease';
        ecoEl.style.opacity = '1';
        ecoEl.style.transform = 'translateY(-36px)';

        ecoTimer = setTimeout(() => {
          ecoEl.style.opacity = '0';
        }, 1400);
      });
    });
  }

  // Init on load and after swaps
  initInteractive();
  document.addEventListener('astro:after-swap', initInteractive);
</script>

<style>
  .obj {
    transform: translate(-50%, -50%);
    will-change: transform;
  }
</style>
